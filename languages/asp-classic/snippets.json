{
    "ASP Response Write":  {
                               "prefix":  "rw",
                               "body":  "Response.Write ${1:expression}",
                               "description":  "Response.Write shorthand"
                           },
    "ASP Response Write Inline":  {
                                      "prefix":  "rwi",
                                      "body":  "\u003c%= ${1:expression} %\u003e",
                                      "description":  "Inline ASP expression output"
                                  },
    "ASP Block":  {
                      "prefix":  "asp",
                      "body":  "\u003c%\n\t${1}\n%\u003e",
                      "description":  "ASP code block"
                  },
    "Dim Variable":  {
                         "prefix":  "dim",
                         "body":  "Dim ${1:varName}",
                         "description":  "Declare variable"
                     },
    "If Statement":  {
                         "prefix":  "if",
                         "body":  "If ${1:condition} Then\n\t${2}\nEnd If",
                         "description":  "If...Then...End If"
                     },
    "If Else Statement":  {
                              "prefix":  "ife",
                              "body":  "If ${1:condition} Then\n\t${2}\nElse\n\t${3}\nEnd If",
                              "description":  "If...Else...End If"
                          },
    "For Loop":  {
                     "prefix":  "for",
                     "body":  "For ${1:i} = ${2:0} To ${3:10}\n\t${4}\nNext",
                     "description":  "For...Next loop"
                 },
    "For Each Loop":  {
                          "prefix":  "foreach",
                          "body":  "For Each ${1:item} In ${2:collection}\n\t${3}\nNext",
                          "description":  "For Each...In...Next loop"
                      },
    "While Loop":  {
                       "prefix":  "while",
                       "body":  "While ${1:condition}\n\t${2}\nWend",
                       "description":  "While...Wend loop"
                   },
    "Do While Loop":  {
                          "prefix":  "dowhile",
                          "body":  "Do While ${1:condition}\n\t${2:\u0027 body}\nLoop",
                          "description":  "Do While...Loop"
                      },
    "Sub Declaration":  {
                            "prefix":  "sub",
                            "body":  "Sub ${1:SubName}(${2})\n\t${3}\nEnd Sub",
                            "description":  "Sub procedure"
                        },
    "Function Declaration":  {
                                 "prefix":  "func",
                                 "body":  "Function ${1:FuncName}(${2})\n\t${3}\n\t${1:FuncName} = ${4:result}\nEnd Function",
                                 "description":  "Function procedure"
                             },
    "Select Case":  {
                        "prefix":  "select",
                        "body":  "Select Case ${1:variable}\n\tCase ${2:value1}\n\t\t${3}\n\tCase Else\n\t\t${4}\nEnd Select",
                        "description":  "Select Case statement"
                    },
    "On Error Resume Next":  {
                                 "prefix":  "oern",
                                 "body":  "On Error Resume Next",
                                 "description":  "Enable error handling"
                             },
    "On Error GoTo 0":  {
                            "prefix":  "oerg",
                            "body":  "On Error GoTo 0",
                            "description":  "Disable error handling"
                        },
    "CreateObject":  {
                         "prefix":  "obj",
                         "body":  "Server.CreateObject(\"${1:whatever}\")",
                         "description":  "Server.CreateObject"
                     },
    "Set Nothing":  {
                        "prefix":  "sn",
                        "body":  "Set ${1:obj} = Nothing",
                        "description":  "Destroy object reference"
                    },
    "Response Redirect":  {
                              "prefix":  "redir",
                              "body":  "Response.Redirect \"${1:url}\"",
                              "description":  "Response.Redirect"
                          },
    "Request Form":  {
                         "prefix":  "rf",
                         "body":  "Request.Form(\"${1:fieldName}\")",
                         "description":  "Request.Form value"
                     },
    "Request QueryString":  {
                                "prefix":  "rqs",
                                "body":  "Request.QueryString(\"${1:paramName}\")",
                                "description":  "Request.QueryString value"
                            },
    "Session Variable":  {
                             "prefix":  "sess",
                             "body":  "Session(\"${1:key}\")",
                             "description":  "Session variable"
                         },
    "Include File":  {
                         "prefix":  "inc",
                         "body":  "\u003c!--#include file=\"${1:filename.asp}\"--\u003e",
                         "description":  "Server-side include"
                     },
    "Include Virtual":  {
                            "prefix":  "incv",
                            "body":  "\u003c!--#include virtual=\"${1:/path/to/file.asp}\"--\u003e",
                            "description":  "Server-side virtual include"
                        },
    "ASP Page Header":  {
                            "prefix":  "asphead",
                            "body":  "\u003c%@ Language=\"VBScript\" CodePage=\"65001\" %\u003e\n\u003c%\nOption Explicit\nResponse.Buffer = True\nResponse.ContentType = \"text/html; charset=utf-8\"\n%\u003e",
                            "description":  "Standard ASP page header"
                        },
    "ADODB Connection":  {
                             "prefix":  "adoconn",
                             "body":  "Dim conn\nSet conn = Server.CreateObject(\"ADODB.Connection\")\nconn.Open \"${1:connectionString}\"\n\n${2}\n\nconn.Close\nSet conn = Nothing",
                             "description":  "ADODB Connection block"
                         },
    "ADODB Recordset":  {
                            "prefix":  "adorec",
                            "body":  "Dim rs\nSet rs = Server.CreateObject(\"ADODB.Recordset\")\nrs.Open \"${1:SELECT * FROM table}\", conn\n\nDo While Not rs.EOF\n\t${2}\n\trs.MoveNext\nLoop\n\nrs.Close\nSet rs = Nothing",
                            "description":  "ADODB Recordset loop"
                        },
    "Scripting Dictionary":  {
                                 "prefix":  "dict",
                                 "body":  "Dim ${1:dict}\nSet ${1:dict} = Server.CreateObject(\"Scripting.Dictionary\")\n${1:dict}.Add \"${2:key}\", ${3:value}",
                                 "description":  "Scripting.Dictionary"
                             },
    "FSO Read File":  {
                          "prefix":  "fsoread",
                          "body":  "Dim fso, f, txt\nSet fso = Server.CreateObject(\"Scripting.FileSystemObject\")\nSet f = fso.OpenTextFile(Server.MapPath(\"${1:file.txt}\"), 1)\ntxt = f.ReadAll\nf.Close\nSet f = Nothing\nSet fso = Nothing",
                          "description":  "FSO read file"
                      },
    "ASP Output Expression":  {
                                  "prefix":  "out",
                                  "body":  "\u003c%=$0%\u003e",
                                  "description":  "ASP \u003c%= %\u003e output"
                              },
    "For Each In":  {
                        "prefix":  "forin",
                        "body":  "For $1 in $2\n\t${3:\u0027 body}\nNext",
                        "description":  "For...in...Next"
                    },
    "Do Until Loop":  {
                          "prefix":  "dountil",
                          "body":  "Do Until ${1:condition}\n\t${2:\u0027 body}\nLoop",
                          "description":  "Do Until...Loop"
                      },
    "Case":  {
                 "prefix":  "case",
                 "body":  "Case ${2:condition}:\n\t${3:\u0027 Do Something}",
                 "description":  "Case branch"
             },
    "Class":  {
                  "prefix":  "class",
                  "body":  "Class ${1:ClassName}\n\n\t${2:\u0027 Add some properties or methods!}\n\nEnd Class\n${3}",
                  "description":  "Class declaration"
              },
    "Response Cookie":  {
                            "prefix":  "cook",
                            "body":  "Response.Cookie(\"${1:whatever}\")",
                            "description":  "Response.Cookie"
                        },
    "Application Variable":  {
                                 "prefix":  "app",
                                 "body":  "Application(\"$1\")",
                                 "description":  "Application variable"
                             },
    "Request Object":  {
                           "prefix":  "req",
                           "body":  "Request",
                           "description":  "Request object"
                       },
    "Response Object":  {
                            "prefix":  "res",
                            "body":  "Response",
                            "description":  "Response object"
                        },
    "Set DB Connection":  {
                              "prefix":  "dbcon",
                              "body":  "Set ${1:Db} = Server.CreateObject(\"ADODB.Connection\")\n${2:Conn} = \"${3:Connection_String}\"\n${1}.Open ${2}\n${4}\n${2}.Close\n${5}",
                              "description":  "ADODB Connection"
                          },
    "Set RecordSet":  {
                          "prefix":  "rs",
                          "body":  "Set ${1:Rs} = Server.CreateObject(\"ADODB.RecordSet\")\n${2:SQL} = \"${3:SQL_QUERY}\"\n${1}.Open ${2}, ${4:Db}\n${5}\n${1}.Close\n${6}",
                          "description":  "ADODB Recordset"
                      }
}
